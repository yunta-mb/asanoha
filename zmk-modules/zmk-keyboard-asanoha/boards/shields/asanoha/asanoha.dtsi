#include <dt-bindings/zmk/matrix_transform.h>
#include "asanoha-layout.dtsi"

/ {
    chosen {
        zmk,kscan = &kscan0;
//        zmk,matrix_transform = &default_transform;
        zmk,physical-layout = &physical_layout0;
        zephyr,console = &cdc_acm_uart;
    };

    matrix_transform0: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <42>;
        rows = <1>;
        map = <
            RC(0,5)  RC(0,4)  RC(0,3)  RC(0,2)  RC(0,1)  RC(0,0)     RC(0,21) RC(0,22) RC(0,23) RC(0,24) RC(0,25) RC(0,26)
            RC(0,11) RC(0,10) RC(0,9)  RC(0,8)  RC(0,7)  RC(0,6)     RC(0,27) RC(0,28) RC(0,29) RC(0,30) RC(0,31) RC(0,32)
            RC(0,17) RC(0,16) RC(0,15) RC(0,14) RC(0,13) RC(0,12)    RC(0,33) RC(0,34) RC(0,35) RC(0,36) RC(0,37) RC(0,38)
                                       RC(0,20) RC(0,19) RC(0,18)    RC(0,39) RC(0,40) RC(0,41)
        >;
    };

    kscan0: kscan_0 {
        compatible = "zmk,kscan-gpio-direct";
        wakeup-source;
        input-gpios =
              <&mcp_io  8 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>
            , <&mcp_io 11 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>
            , <&mcp_io 13 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>
            , <&mcp_io 15 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>
            , <&mcp_io  3 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>
            , <&xiao_d  8 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>

            , <&mcp_io  9 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>
            , <&mcp_io 10 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>
            , <&mcp_io 12 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>
            , <&mcp_io 14 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>
            , <&mcp_io  7 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>
            , <&mcp_io  2 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>

            , <&mcp_io  6 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>
            , <&mcp_io  4 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>
            , <&mcp_io  5 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>
            , <&mcp_io  0 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>
            , <&mcp_io  1 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>
            , <&xiao_d  7 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>

            , <&xiao_d  6 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>
            , <&xiao_d  3 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>
            , <&xiao_d  2 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>

//            , <&xiao_d  0 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>
//            , <&xiao_d  1 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>
//            , <&xiao_d  9 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>
        ;
    };

};

&xiao_spi { status = "disabled"; };
&xiao_serial { status = "disabled"; };

&xiao_i2c {
	status = "okay";
	clock-frequency = <I2C_BITRATE_FAST>;

    mcp_io: mcp23017@20 {
        compatible = "microchip,mcp23017";
        status = "okay";
        gpio-controller;
        int-gpios = <&xiao_d 10 (GPIO_ACTIVE_LOW)>;
        reg = <0x20>;
        #gpio-cells = <2>;
        ngpios = <16>;
    };
};

&usbd {
  status = "okay";
  cdc_acm_uart: cdc_acm_uart {
    compatible = "zephyr,cdc-acm-uart";
  };
};
